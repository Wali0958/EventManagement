    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const textbox = document.getElementById('BadgeId');
            if (textbox) {
                textbox.addEventListener('focus', function () {
                    this.select(); // selects all text when focused
                });
            }
        });
    </script>
</body>
</html>
