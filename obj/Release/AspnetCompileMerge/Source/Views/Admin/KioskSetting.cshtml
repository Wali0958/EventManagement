@model EventManagement.Models.Kiosk

@{
    ViewBag.Title = "KioskSetting";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container bg-light">
    <div class="m-3">
        <section class="row">
            <h3 class="p-1">Add/View Kiosk (Event wise)</h3>
            <div class="col-12 m-2">
                @using (Html.BeginForm("AddKioskSetting", "Admin", FormMethod.Post, new { @class = "", role = "form", enctype = "multipart/form-data" }))
                {
                    <div class="row">
                        <div class="col-6 p-2">
                            <label>Select Event</label>
                            <select id="ddlEventId" name="EventId" class="form-select" tabindex="1">
                                @if (Model?.EventDrop != null)
                                {
                                    foreach (var item in Model.EventDrop)
                                    {
                                        <option value="@item.EventId">@item.EventName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-6 p-2">
                            <label>Select Background Image</label>
                            <input type="file" id="kioskbg" name="kioskbg" required="required" class="form-control" />
                        </div>
                        <label>Logo or Title details</label>
                        <textarea cols="5" rows="5" class="form-control" name="title" placeholder="Please enter title or other details"></textarea>
                        <div class="clearfix mt-2"></div>
                        <div class="clearfix mt-2"></div>
                    </div>
                    <div class="clearfix mt-2"></div>
                    <div class="text-center">
                        <input type="submit" value="Submit" class="btn btn-success" />
                        <input type="submit" value="Reset" class="btn btn-warning" />
                    </div>
                }
                <div class="clearfix mt-2"></div>
                <table id="tblprint" class="table table-responsive table-success table-hover table-bordered mtable">
                    <thead>
                        <tr>
                            <th>Sr.No</th>
                            <th>Event Name</th>
                            <th>Bg Image</th>
                            <th>Quotes</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.KioskList != null)
                        {
                            int count = 1;
                            foreach (var item in Model.KioskList)
                            {
                                <tr>
                                    <td>@count</td>
                                    <td>@item.EventName</td>
                                    <td><img src="~/Content/Kiosk/@item.KioskBg" height="100px" width="100px" class="img img-responsive" /></td>
                                    <td>@item.Title</td>
                                    <td>@(item.IsActive ? "Active" : "Deactive")</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            @Html.ActionLink("Deactive", "DeactiveKiosk", "Admin", new { id = item.KioskId }, new { @class = "btn btn-warning" })
                                        }
                                        else
                                        {
                                            @Html.ActionLink("Active", "ActiveKiosk", "Admin", new { id = item.KioskId }, new { @class = "btn btn-success" })
                                        }
                                        <div class="clearfix mt-1"></div>
                                        @Html.ActionLink("Delete", "DeleteKiosk", "Admin", new { id = item.KioskId }, new { @class = "btn btn-danger" })

                                    </td>
                                </tr>
                                count++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>

