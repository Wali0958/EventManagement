@model List<EventManagement.Models.GetPrintBadge>

@{
    int count = 1;
}
@if (Model != null)
{
    foreach (var item in Model)
    {
        <tr>
            <td><input type="checkbox" class="row-checkbox" checked="checked" style="pointer-events:none;" value="@item.BadgeId" /></td>
            <td>@count</td>
            <td>@item.Category</td>
            <td>@item.Name <div class="clearfix mt-2"></div>@item.Mobile <div class="clearfix mt-2"></div>@item.Email<div class="clearfix mt-2"></div>@item.Country</td>
            <td>@item.Designation</td>
            <td>@item.Company</td>
            <td>@(item.IsPrint == "YES" ? "Yes" : "No") / @item.PrintOn</td>
            <td>@(item.KitCollect== "YES" ? "Yes":"No") /@item.CollectOn / @item.CollectBy </td>
            <td>@item.RecInsTime</td>
            @*@if (item.IsPrint == "YES")
                {
                    <td><input type="submit" value="Re-Print" class="btn btn-warning" onclick="Reprint('@item.BadgeId')" name="Print" /></td>
                }
                else
                {
                    <td><input type="submit" value="Print" class="btn btn-success" onclick="PrintBadge('@item.BadgeId')" name="Print" /></td>
                }*@
        </tr>
        count++;
    }
}
<script>
    (function () {
        const selectAll = document.getElementById('selectAll');
        if (!selectAll) return;

        const checkboxes = document.querySelectorAll('.row-checkbox');

        selectAll.addEventListener('change', function () {
            checkboxes.forEach(cb => cb.checked = this.checked);
        });

        checkboxes.forEach(cb => {
            cb.addEventListener('change', function () {
                if (!this.checked) {
                    selectAll.checked = false;
                } else if (document.querySelectorAll('.row-checkbox:checked').length === checkboxes.length) {
                    selectAll.checked = true;
                }
            });
        });
    })();
</script>
