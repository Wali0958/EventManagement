<script>
    function PrintMultipleRecordAll() {

    var mstatusvalue =  $('input[type=radio][name=IsPrint]:checked').val();   
    var selectedIds = [];
    $('.row-checkbox:checked').each(function () {
        selectedIds.push($(this).val());
    });
    var mId = selectedIds;
    if (selectedIds.length === 0) {
        alert("Please select at least one badge.");
        return;
    }
    $.ajax({
        url: '@Url.Action("MultiplePrintBadgeCodeSearch", "Home")',
        type: 'GET',
        traditional: true, // IMPORTANT for sending arrays to MVC
        data: { BadgeId: selectedIds },
        success: function (response) {
            if (response.success) {
                $('#divshowpanel').html(response.mData);
                setTimeout(function () {
                    var divContents = $(".print-page").map(function () { return '<div class="print-page">' + $(this).html() + '</div>'; }).get().join('');
                    var printWindow = window.open('', '', 'height=600,width=800');
                    printWindow.document.write('<html><head>');
                    printWindow.document.write(`
                   <style>
                      @@media print {
                         body {
                             margin: 0;
                             padding: 0;
                         }
                        .print-page {
                            page-break-after: always;
                            width: 100%;
                            box-sizing: border-box;
                            text-align: center;  /* center text, but not force flex */
                        }
                         .print-page:last-child {
                             page-break-after: auto;
                         }
                     }
                      </style>
                `);
                    printWindow.document.write('</head><body>');
                    printWindow.document.write(divContents);
                    printWindow.document.write('</body></html>');
                    printWindow.document.close();
                    printWindow.focus();
                    printWindow.print();
                    printWindow.close();
                    // update print status
                    $.ajax({
                        url: '@Url.Action("updatebadgeafterbulkprintstatus", "Home")',
                        type: 'POST',
                        traditional: true, // again for arrays
                        data: { multiprint: mId, mstatus: mstatusvalue },
                        success: function (updateResponse) {
                            if (updateResponse.success) {
                                alert('Re-Print successful and status updated.');
                                window.location.href = '@Url.Action("Index", "Home")';
                            } else {
                                alert("Oops! Error occurred while updating print status.");
                            }
                        },
                        error: function () {
                            alert('An error occurred while updating print status.');
                        }
                    });
                }, 500);
            } else {
                alert(response.message);
                window.location.href = '@Url.Action("Index", "Home")';
            }
        },
        error: function () {
            alert('An error occurred');
        }
    });
}
</script>