@model EventManagement.Models.BadgeDetailsScanning
@{
    ViewBag.Title = "Scanning";
    Layout = "~/Views/Shared/_Layout.cshtml";

}
<div class="container bg-light">
    <div class="m-3">
        <section class="row">
            <h3 class="p-1">Scanning</h3>
            <div class="col-12 m-2">
                <div class="row">
                    <div class="col-md-9"></div>
                    <div class="col-md-3">
                        <div id="divcompsny">
                            <input type="text" id="BadgeId" tabindex="1" autofocus="" name="BadgeId" maxlength="15"
                                   placeholder="Scan the QR and Others" autocomplete="on" autofocus class="form-control" />
                        </div>
                    </div>
                    <div class="clearfix mt-1"></div>
                    <div id="divprint">
                    </div>
                </div>
                <div class="clearfix mt-2"></div>
                <br />
            </div>
        </section>
    </div>
</div>
<script src="~/Scripts/jquery-3.7.0.min.js"></script>
<script>
     $(document).ready(function () {
         let typingTimer;
         const doneTypingInterval = 500; // Wait time (ms) before triggering AJAX on typing
         const $input = $('#BadgeId');
         // Trigger AJAX call
         function triggerAjax() {
             const textValue = $input.val().trim();
             if (textValue.length === 0) return; // Don’t call if empty
             $.ajax({
                 url: '@Url.Action("ScanningData", "Home")',
                 type: 'GET',
                 data: { input: textValue },
                 success: function (response) {
                     $('#divprint').html(response);
                 },
                 error: function () {
                     $('#divprint').html("Error retrieving data.");
                 }
             });
         }

         // When typing — delay the AJAX trigger
         $input.on('input', function () {
             clearTimeout(typingTimer);
             typingTimer = setTimeout(triggerAjax, doneTypingInterval);
         });

         // When pressing Enter (for scanners that send Enter)
         $input.on('keypress', function (e) {
             if (e.which === 13) { // Enter key
                 e.preventDefault();
                 clearTimeout(typingTimer);
                 triggerAjax();
             }
         });
     });
</script>

