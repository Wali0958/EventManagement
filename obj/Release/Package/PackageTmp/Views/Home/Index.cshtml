@model EventManagement.Models.GetPrintBadge
@{
    ViewBag.Title = "Home Page";
    var media = "";
}

<div class="container bg-light">
    <div class="m-3">
        <section class="row">
            <div class="text-danger">
                <p>Notes:- 1. For print select badge and print. (you can print multiple badge at a single time for various category.)</p>
                <p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;2. For re-print click on Printed radio button then select badge or re-print it.</p>
            </div>
            <div class="col-12 m-2">
                <div class="row">
                    <div class="col-4">
                        <label>Please select which badge you want to display</label>
                        <div class="form-control">
                            <label>
                                <input type="radio" id="rdprint" class="rounded" name="IsPrint" value="0" />
                                For Print |
                            </label>&nbsp;
                            <label>
                                <input type="radio" id="rdprinted" name="IsPrint" value="1" />
                                Printed
                            </label>
                        </div>
                    </div>
                    <div class="col-4">
                        <lable>Category</lable>
                        <select id="Category" name="Category" class="form-control">
                            <option value="">All</option>
                            @if (Model?.EventWiseCategory != null)
                            {
                                foreach (var item in Model.EventWiseCategory)
                                {
                                    <option value="@item.CategoryName">@item.CategoryName</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-4">
                        <lable>Company Name</lable>
                        <select id="company" name="Company" class="form-control">
                            <option value="">All</option>
                            @if (Model?.BadgeCompany != null)
                            {
                                foreach (var item in Model.BadgeCompany)
                                {
                                    <option value="@item.Company">@item.Company</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="clearfix mt-2"></div>

                <br />
                <style>
                    .no-sort::after {
                        display: none;
                    }
                </style>
                <div class="clearfix mt-2"></div>
                <input type="submit" value="Multiple Print at One time" id="multipleprintbtn" onclick="PrintMultipleRecordAll();" class="btn btn-info float-end mr-2 mb-2 d-none" name="Print" />
                <br />
                <table id="tblprint" class="table table-responsive table-success table-hover table-bordered">
                    <thead class="sticky-top">
                        <tr>
                            <th class="no-sort"><input type="checkbox" id="selectAll" checked="checked" style="pointer-events:none;" /> All</th>
                            <th>Sr.No</th>
                            <th>Category</th>
                            <th>Name/Mobile/Email</th>
                            <th>Designation</th>
                            <th>Company</th>
                            <th>Print Status</th>
                            <th>Kit Status</th>
                            <th>Insert-On</th>
                            @*<th>Action</th>*@
                        </tr>
                    </thead>
                    <tbody>
                        @*@if (Model?.ListBadgeCompany != null)
                            {
                                int count = 1;
                                foreach (var item in Model.ListBadgeCompany)
                                {
                                    <tr>
                                        <td><input type="checkbox" class="row-checkbox" value="@item.BadgeId" /></td>
                                        <td>@count</td>
                                        <td>@item.Category</td>
                                        <td>@item.Company</td>
                                        <td>@item.Name</td>
                                        <td>@item.Designation</td>
                                        <td>@item.Mobile</td>
                                        <td>@(item.IsPrint == "YES" ? "Yes" : "No") / @item.PrintOn</td>
                                        <td>@(item.KitCollect== "YES" ? "Yes":"No") /@item.CollectOn / @item.CollectBy </td>
                                        <td>@item.RecInsTime</td>
                                        @if (item.IsPrint == "YES")
                                        {
                                            <td><input type="submit" value="Re-Print" class="btn btn-warning" onclick="RePrintBadge('@item.BadgeId')" name="Print" /></td>
                                        }
                                        else
                                        {
                                            <td><input type="submit" value="Print" class="btn btn-success" onclick="PrintBadge('@item.BadgeId')" name="Print" /></td>
                                        }
                                    </tr>
                                    count++;
                                }
                            }*@
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>
<div id="divshowpanel" style="display:none;"></div>

