@model EventManagement.Models.Dashboard
@{
    ViewBag.Title = "AdminDashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    <style>
        .mdashboard {
            border-radius: 14px;
            padding: 20px;
            border: 1px solid rgba(255,255,255,.3); /* FIX */
            box-shadow: 0 8px 20px rgba(0,0,0,.12);
        }

            .mdashboard:hover {
                transform: translateY(-4px);
            }

        .stat-icon {
            font-size: 40px;
            opacity: .85;
        }
    </style>
}

<div class="container bg-light">
    <div class="m-3">
        <section class="row">
            <h3 class="p-1">Admin Dashboard</h3>
            <div class="clearfix mt-1"></div>
            <br />
            <div class="col-md-12">
                <div class="row text-white text-center g-3">

                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="bg-primary mdashboard">
                            <i class="fa fa-calendar stat-icon"></i>
                            <h5 class="mt-2">Total Event</h5>
                            <h3>@Model.TotalEvent</h3>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="bg-success mdashboard">
                            <i class="fa fa-users stat-icon"></i>
                            <h5 class="mt-2">Total User</h5>
                            <h3>@Model.TotalUser</h3>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="bg-danger mdashboard">
                            <i class="fa fa-print stat-icon"></i>
                            <h5 class="mt-2">Badge Printed</h5>
                            <h3>@Model.TotalBadge</h3>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="bg-warning text-dark mdashboard">
                            <i class="fa fa-times-circle stat-icon"></i>
                            <h5 class="mt-2">Not Printed</h5>
                            <h3>@Model.TotalBadgeNo</h3>
                        </div>
                    </div>

                </div>

                <div class="clearfix"></div>
                <table id="tblprint" class="table table-bordered table-hover align-middle table-striped shadow-sm mtable">
                    <thead class="table-dark">
                        <tr>
                            <th>Sr.No</th>
                            <th>Event Name</th>
                            <th>Total Count</th>
                            <th>Event Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.EventExcelUpload != null)
                        {
                            int count = 1;
                            foreach (var item in Model.EventExcelUpload)
                            {
                                DateTime mDate = @item.EventDate;
                                string mFinalDate = mDate.ToString("dd-MMMM-yyyy");
                                <tr>
                                    <td>@count</td>
                                    <td>@item.EventName</td>
                                    <td>@item.TotalExcel</td>
                                    <td>@mFinalDate</td>
                                    <td>
                                        <a class="btn btn-success" id="btnshow" href="#" onclick="ShowAllbadge(@item.EventId)">View Badges</a>
                                    </td>
                                </tr>
                                count++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
        <div class="clearfix mt-1"></div>
        <br />
    </div>
</div>
<div class="modal" tabindex="-1" id="mdlBadge" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog  modal-lg">
        <div class="modal-content" style="background-color:#F1F1F1">
            <div class="modal-header">
                <h5 class="modal-title"><b>Alert</b></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="col-12 m-2" style="overflow:scroll;">
                    <table id="tblprint" class="table table-bordered table-hover align-middle table-striped shadow-sm mtable">
                        <thead class="table-dark">
                            <tr>
                                <th>Sr.No</th>
                                <th>Category</th>
                                <th>Special No</th>
                                <th>NAME</th>
                                <th>Designation</th>
                                <th>Company</th>
                                <th>Mobile</th>
                                <th>Country</th>
                                <th>ID Type</th>
                                <th>ID Number</th>
                                <th>Photo</th>
                                <th>Is Print</th>
                                <th>Print On</th>
                                <th>Is Reprint</th>
                                <th>Reprint On</th>
                                <th>Remarks</th>
                                <th>Data Insert by</th>
                                <th>Is Active</th>
                                <th>Is Visit</th>
                                <th>Visit On</th>
                                <th>Kit Collect</th>
                                <th>Collect On</th>
                                <th>Collect By</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="tblBadge">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    function ShowAllbadge(vId) {
         $.ajax({
            type: "GET",
            url: '@Url.Action("GetAllBadges", "Admin")',
            data: { EventId: vId},
            success: function (data) {
                $("#tblBadge").empty();
                $("#tblBadge").append(data);
                $("#mdlBadge").modal('show');
            },
            error: function (xhr, status, error) {
                alert("Error occurred");
            }
        });
    }
</script>

