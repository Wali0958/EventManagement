@model  EventManagement.Models.EventPrintSetup

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="clearfix mt-2"></div>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
<style>

    .tool {
        padding: 8px;
        margin-bottom: 5px;
        cursor: grab;
    }

    .selected {
        border: 2px solid red;
    }

    .img-wrapper {
        width: 100px;
        height: 100px;
    }

        .img-wrapper img {
            width: 100%;
            height: 100%;
            pointer-events: none; /* 🔥 main fix */
        }

    .draggable {
        position: absolute;
        cursor: move;
        border: 1px dashed #ccc;
        padding: 5px;
        z-index: 9999;
        display: inline-block;
    }

    .save-loader-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.55);
        z-index: 999999;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(3px);
    }

    .save-loader-box {
        width: 280px;
        background: #fff;
        padding: 30px;
        border-radius: 18px;
        text-align: center;
        box-shadow: 0 10px 35px rgba(0,0,0,0.2);
        animation: popupAnim .3s ease;
    }

    .save-spinner {
        width: 70px;
        height: 70px;
        border: 6px solid #e9ecef;
        border-top: 6px solid #0d6efd;
        border-radius: 50%;
        margin: auto;
        animation: spin .8s linear infinite;
    }

    @@keyframes spin {
        100% {
            transform: rotate(360deg);
        }
    }

    @@keyframes popupAnim {
        from {
            transform: scale(.8);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>
<div class="container-fluid">
    <div class="m-3">
        <section class="row">
            <div class="col-12 m-2">
                <div class="row">
                    <div class="col-12 p-2 form-card">
                        <div id="saveLoader" class="text-center mt-2 d-none">
                            <div class="spinner-border text-primary"></div>
                            <div>Please wait...</div>
                        </div>
                        <h5 class="form-section-title">
                            <i class="fa fa-calendar-plus"></i> Master Print Setup (Drag Drop)
                        </h5>
                        <div id="divEvent">
                            <label>Select Event</label>
                            <select id="EventId" name="EventId" class="form-select" tabindex="1">
                                @if (Model?.EventDrop != null)
                                {
                                    <option value="0">--Select--</option>
                                    foreach (var item in Model.EventDrop)
                                    {
                                        <option value="@item.EventId">@item.EventName</option>
                                    }
                                }
                            </select>
                        </div>
                        <br />
                        <div class="row d-none" id="divshowcontent">
                            <div class="col-9">
                                <div style="display:flex;gap:20px">
                                    <div class="col-sm-4">
                                        <p>Fields</p>
                                        <div id="dynamicFieldsContainer"></div>
                                    </div>
                                    <div class="col-sm-2">
                                        <p>For update font type </p>
                                        <button class="btn btn-primary" onclick="setBold()">Font Bold</button>

                                        <button class="btn btn-primary" onclick="setItalic()">Font Italic</button>
                                    </div>
                                    <div class="col-sm-2">
                                        <p>For update font </p>
                                        <select class="form-select mt-2" onchange="setFontFamily(this.value)">
                                            <option value="">-- Select Font Family --</option>

                                            <option value="Times New Roman">Times New Roman</option>
                                            <option value="Georgia">Georgia</option>
                                            <option value="Garamond">Garamond</option>
                                            <option value="Palatino">Palatino</option>
                                            <option value="Book Antiqua">Book Antiqua</option>
                                            <option value="Times">Times</option>

                                            <option value="Arial">Arial</option>
                                            <option value="Helvetica">Helvetica</option>
                                            <option value="Verdana">Verdana</option>
                                            <option value="Tahoma">Tahoma</option>
                                            <option value="Trebuchet MS">Trebuchet MS</option>
                                            <option value="Calibri">Calibri</option>

                                            <option value="Courier New">Courier New</option>
                                            <option value="Monaco">Monaco</option>
                                            <option value="Lucida Console">Lucida Console</option>

                                            <option value="Brush Script MT">Brush Script MT</option>
                                            <option value="Dancing Script">Dancing Script</option>

                                            <option value="Comic Sans MS">Comic Sans MS</option>
                                            <option value="Impact">Impact</option>
                                            <option value="Copperplate">Copperplate</option>
                                            <option value="Papyrus">Papyrus</option>
                                        </select>
                                    </div>
                                    <div class="col-3">
                                        <p>For update Size </p>
                                        <input type="number" class="form-control" placeholder="Font Size (type and enter)" onchange="setFontSize(this.value)" />
                                    </div>

                                </div>
                            </div>
                            <div class="col-3">
                                <div>
                                    <h4>Badge Preview</h4>
                                    <div style="margin-top:10px">
                                    </div>
                                    <div class="clearfix mt-2"></div>
                                    <div id="badgeContainer" class="text-center"></div>
                                    <br />
                                    <div class="text-center">
                                        <button id="btnSaveLayout"
                                                onclick="saveLayout()"
                                                class="btn btn-success text-center">
                                            Save Template
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>
    </div>
</div>
<!-- SAVE LOADER -->
<div id="saveLoaderOverlay" class="save-loader-overlay d-none">

    <div class="save-loader-box">

        <div class="save-spinner"></div>

        <h5 class="mt-3">Saving Template...</h5>

        <p>Please wait</p>

    </div>

</div>
<script src="~/Scripts/jquery-3.7.1.min.js"></script>
<script src="~/Scripts/jquery-ui.min.js"></script>
<script>

    let selected = null;

    const DUMMY_PHOTO = "/Content/BadgePhoto/Dummybadgephoto.jpg";
    const DUMMY_QR = "/Content/QRCodesScanner/DummyQR.png";

    // ================= EVENT CHANGE =================

    $("#EventId").change(function () {

        let eventId = $(this).val();
        if (eventId == 0) {
            $("#divshowcontent").addClass("d-none");
            return;
        }
        $("#saveLoaderOverlay").removeClass("d-none");
        $.ajax({
             url: '@Url.Action("GetColumnsByFilterDrag", "Admin")',
            type: 'GET',
            data: { EventId: eventId },
            success: function (res) {
                $("#badgeContainer").html(res.badgeHtml);
                renderFields(res.columns);
                initBadge();
                $("#badgeArea .draggable").remove();
                if (res.settings && res.settings.length > 0) {
                    loadSavedLayout(res.settings);
                }
                $("#divshowcontent").removeClass("d-none");
                $("#saveLoaderOverlay").addClass("d-none");
            }
        });
    });

    // ================= RENDER FIELDS =================

    function renderFields(data) {

        let container = $("#dynamicFieldsContainer");
        container.empty();
        if (!data) return;
        let fieldsMap = {
            RName: "Name",
            Designation: "Designation",
            Company: "Company",
            Category: "Category",
            Country: "Country",
            Photo: "Photo",
            BarCode: "QR Code"
        };
        Object.keys(fieldsMap).forEach(key => {
            if (data[key] === true) {
                let type = "text";
                if (key === "Photo") type = "image";
                if (key === "BarCode") type = "barcode";
                let btn = `
                    <div class="btn btn-info btn-sm tool"
                         data-field="${key}"
                         data-type="${type}">
                         ${fieldsMap[key]}
                    </div>
                `;

                container.append(btn);
            }
        });
        $(".tool").draggable({

            helper: "clone",
            revert: "invalid"
        });
    }
    function initBadge() {

        let badge = $("#badgeArea");

        if (badge.data("ui-droppable")) {

            badge.droppable("destroy");
        }

        badge.droppable({

            accept: ".tool",

            drop: function (event, ui) {

                let field = ui.helper.data("field");

                let type = ui.helper.data("type");

                let exists =
                    badge.find(`[data-field='${field}']`).length > 0;

                if (exists) {

                    alert(field + " already added!");

                    return;
                }

                let newEl;

                if (type === "image") {

                    newEl = $(`
                        <div class="img-wrapper draggable">
                            <img src="${DUMMY_PHOTO}" />
                        </div>
                    `);
                }
                else if (type === "barcode") {

                    newEl = $(`
                        <div class="img-wrapper draggable">
                            <img src="${DUMMY_QR}" />
                        </div>
                    `);
                }
                else {

                    newEl = $(`<div class="draggable">${field}</div>`);
                }

                newEl.attr("data-field", field);

                newEl.attr("data-type", type);

                newEl.css({

                    position: "absolute",

                    top: ui.offset.top - badge.offset().top,

                    left: ui.offset.left - badge.offset().left,

                    zIndex: 9999
                });

                badge.append(newEl);

                makeInteractive(newEl);
            }
        });
    }

    // ================= LOAD SAVED =================

    function loadSavedLayout(settings) {

        settings.forEach(item => {

            let field = item.ColumName;

            let exists =
                $("#badgeArea")
                    .find(`[data-field='${field}']`)
                    .length > 0;

            if (exists) return;

            let el;

            if (item.ColType === "image") {

                el = $(`
                    <div class="img-wrapper draggable">
                        <img src="${DUMMY_PHOTO}" />
                    </div>
                `);
            }
            else if (item.ColType === "barcode") {

                el = $(`
                    <div class="img-wrapper draggable">
                        <img src="${DUMMY_QR}" />
                    </div>
                `);
            }
            else {

                el = $(`<div class="draggable">${field}</div>`);
            }

            el.attr("data-field", field);

            el.attr("data-type", item.ColType);

            el.css({

                position: "absolute",

                top: item.MarginTop,

                left: item.MarginLeft,

                width: item.TotalWidth,

                height: item.TotalHeight,

                fontSize: item.FontSize + "px",

                fontFamily: item.FontFamily || "Arial",

                fontWeight: item.FontWeight,

                fontStyle: item.FontStyle,

                zIndex: 9999
            });

            $("#badgeArea").append(el);

            makeInteractive(el);
        });
    }

    // ================= INTERACTIVE =================

    function makeInteractive(el) {

        if (el.data("ui-draggable")) {

            el.draggable("destroy");
        }

        if (el.data("ui-resizable")) {

            el.resizable("destroy");
        }

        el.draggable({

            containment: "#badgeArea",

            cursor: "move",

            cancel: "img",

            start: function () {

                $(this).css("z-index", 9999);
            }

        }).resizable();

        el.off("click").on("click", function (e) {

            e.stopPropagation();

            $(".draggable").removeClass("selected");

            $(this).addClass("selected");

            selected = $(this);
        });
    }

    // ================= DESELECT =================

    $(document).on("click", "#badgeArea", function () {

        $(".draggable").removeClass("selected");

        selected = null;
    });

    // ================= STYLE =================

    function setBold() {

        if (!selected) return;

        selected.css("font-weight", "bold");
    }

    function setItalic() {

        if (!selected) return;

        selected.css("font-style", "italic");
    }

    function setFontSize(size) {

        if (!selected) return;

        if (
            selected.data("type") === "image" ||
            selected.data("type") === "barcode"
        ) {
            alert("Font only for text");
            return;
        }

        selected.css("font-size", size + "px");
    }

    function setFontFamily(font) {

        if (!selected) return;

        if (
            selected.data("type") === "image" ||
            selected.data("type") === "barcode"
        ) {
            alert("Font only for text");
            return;
        }

        selected.css("font-family", font);
    }

    // ================= SAVE =================

    function saveLayout() {
        let layout = [];
        $("#badgeArea .draggable").each(function () {
            let el = $(this);
            layout.push({
                field: el.data("field"),
                type: el.data("type"),
                top: parseInt(el.css("top")),
                left: parseInt(el.css("left")),
                width: el.width(),
                height: el.height(),
                fontSize:
                    parseInt(el.css("font-size")) || 14,
                fontFamily: el.css("font-family"),
                bold:
                    el.css("font-weight") == "700" ||
                    el.css("font-weight") == "bold",

                italic:
                    el.css("font-style") == "italic"
            });
        });

        $("#saveLoaderOverlay").removeClass("d-none");
        $("#btnSaveLayout").prop("disabled", true);
        $.ajax({
            url: '@Url.Action("SaveTemplate","Admin")',

            type: 'POST',
            data: JSON.stringify({
                EventId: $("#EventId").val(),
                LayoutJson: JSON.stringify(layout),
                BackgroundImage: "/uploads/badge.png"
            }),
            contentType: 'application/json',
            success: function (res) {
                if (res.success) {
                    alert(res.msg);
                }
                else {
                    alert(res.msg);
                }
            },
            error: function () {
                alert("Something went wrong");
            },
            complete: function () {
                $("#saveLoaderOverlay").addClass("d-none");
                $("#btnSaveLayout").prop("disabled", false);
            }
        });
    }

</script>
