@model  EventManagement.Models.EventPrintSetup

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="clearfix mt-2"></div>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
<style>

    .tool {
        padding: 8px;
        margin-bottom: 5px;
        cursor: grab;
    }

    .selected {
        border: 2px solid red;
    }

    .img-wrapper {
        width: 100px;
        height: 100px;
    }

        .img-wrapper img {
            width: 100%;
            height: 100%;
            pointer-events: none; /* 🔥 main fix */
        }

    .draggable {
        position: absolute;
        cursor: move;
        border: 1px dashed #ccc;
        padding: 5px;
        z-index: 9999;
        display: inline-block;
    }
    .save-loader-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.55);
        z-index: 999999;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(3px);
    }

    .save-loader-box {
        width: 280px;
        background: #fff;
        padding: 30px;
        border-radius: 18px;
        text-align: center;
        box-shadow: 0 10px 35px rgba(0,0,0,0.2);
        animation: popupAnim .3s ease;
    }

    .save-spinner {
        width: 70px;
        height: 70px;
        border: 6px solid #e9ecef;
        border-top: 6px solid #0d6efd;
        border-radius: 50%;
        margin: auto;
        animation: spin .8s linear infinite;
    }

    @@keyframes spin {
        100% {
            transform: rotate(360deg);
        }
    }

    @@keyframes popupAnim {
        from {
            transform: scale(.8);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>
<div class="container-fluid">
    <div class="m-3">
        <section class="row">
            <div class="col-12 m-2">
                <div class="row">
                    <div class="col-12 p-2 form-card">
                        <h5 class="form-section-title">
                            <i class="fa fa-calendar-plus"></i> Master Print Setup
                        </h5>
                        <div id="divEvent">
                            <label>Select Event</label>
                            <select id="EventId" name="EventId" class="form-select" tabindex="1">
                                @if (Model?.EventDrop != null)
                                {
                                    <option value="0">--Select--</option>
                                    foreach (var item in Model.EventDrop)
                                    {
                                        <option value="@item.EventId">@item.EventName</option>
                                    }
                                }
                            </select>
                        </div>
                        <br />
                        <div class="row d-none" id="divshowcontent">
                            <div class="col-3">
                                <div style="display:flex;gap:20px">
                                    <div>
                                        <h4>Fields</h4>
                                        <div id="dynamicFieldsContainer"></div>
                                        <div class="clearfix mt-1"></div>
                                        <p>For update font type/size </p>
                                        <button class="btn btn-primary" onclick="setBold()">Font Bold</button>
                                        <button class="btn btn-primary" onclick="setItalic()">Font Italic</button>
                                        <div class="clearfix mt-1"></div>
                                        <input type="number" class="form-control" placeholder="Font Size (type and enter)" onchange="setFontSize(this.value)" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-9">
                                <div>
                                    <h4>Badge Preview</h4>
                                    <div style="margin-top:10px">
                                    </div>
                                    <div class="clearfix mt-2"></div>
                                    <div id="badgeContainer" class="text-center"></div>
                                    <br />
                                    <div class="text-center">
                                        <button onclick="saveLayout()" class="btn btn-success text-center">Save Template</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>
    </div>
</div>
<!-- SAVE LOADER -->
<div id="saveLoaderOverlay" class="save-loader-overlay d-none">
    <div class="save-loader-box">
        <div class="save-spinner"></div>
        <h5 class="mt-3">Saving Template...</h5>
        <p>Please wait</p>
    </div>

</div>
<script src="~/Scripts/jquery-3.7.1.min.js"></script>
<script src="~/Scripts/jquery-ui.min.js"></script>
<script>

    let selected = null;

    const DUMMY_PHOTO = "/Content/BadgePhoto/Dummybadgephoto.jpg";
    const DUMMY_QR = "/Content/QRCodesScanner/DummyQR.png";


    // ================= EVENT CHANGE =================
    $("#EventId").change(function () {

        let eventId = $(this).val();

        if (eventId == 0) {
            $("#divshowcontent").addClass("d-none");
            return;
        }
        $("#saveLoaderOverlay").removeClass("d-none");
        $.ajax({
            url: '/Admin/GetCertificateColumnsByFilterDrag',
            type: 'GET',
            data: { EventId: eventId },
            success: function (res) {
                $("#badgeContainer").html(res.badgeHtml);
                renderFields(res.columns);
                initBadge();
                if (res.settings && res.settings.length > 0) {
                    loadSavedLayout(res.settings);
                }
                $("#divshowcontent").removeClass("d-none");
                $("#saveLoaderOverlay").addClass("d-none");
            }
        });

    });


    // ================= RENDER FIELDS =================
    function renderFields(data) {

        let container = $("#dynamicFieldsContainer");
        container.empty();

        if (!data) return;

        let fieldsMap = {
            RName: "Name",
            Designation: "Designation",
            Company: "Company",
            Category: "Category",
            BarCode: "QR Code"
        };

        Object.keys(fieldsMap).forEach(key => {

            if (data[key] === true) {

                let type = "text";
                if (key === "Photo") type = "image";
                if (key === "BarCode") type = "barcode";

                let btn = `
                <div class="btn btn-info btn-sm tool"
                     data-field="${key}"
                     data-type="${type}">
                     ${fieldsMap[key]}
                </div>
            `;

                container.append(btn);
            }

        });

        $(".tool").draggable({
            helper: "clone",
            revert: "invalid"
        });
    }


    // ================= INIT BADGE =================
    function initBadge() {

        let badge = $("#badgeArea");

        if (badge.data("ui-droppable")) {
            badge.droppable("destroy");
        }

        badge.droppable({
            accept: ".tool",
            drop: function (event, ui) {

                let field = ui.helper.data("field");
                let type = ui.helper.data("type");

                let exists = badge.find(`[data-field='${field}']`).length > 0;

                if (exists) {
                    alert(field + " already added!");
                    return;
                }

                let newEl;

                if (type === "image") {
                    newEl = $(`
                    <div class="img-wrapper draggable">
                        <img src="${DUMMY_PHOTO}" />
                    </div>
                `);
                }
                else if (type === "barcode") {
                    newEl = $(`
                    <div class="img-wrapper draggable">
                        <img src="${DUMMY_QR}" />
                    </div>
                `);
                }
                else {
                    newEl = $(`<div class="draggable">${field}</div>`);
                }

                newEl.attr("data-field", field);
                newEl.attr("data-type", type);

                newEl.css({
                    position: "absolute",
                    top: ui.offset.top - badge.offset().top,
                    left: ui.offset.left - badge.offset().left,
                    zIndex: 9999
                });

                badge.append(newEl);

                makeInteractive(newEl);
            }
        });
    }


    // ================= LOAD SAVED =================
    function loadSavedLayout(settings) {

        settings.forEach(item => {

            let field = item.ColumName;

            let exists = $("#badgeArea").find(`[data-field='${field}']`).length > 0;
            if (exists) return;

            let el;
             if (field === "BarCode") {
                el = $(`
                <div class="img-wrapper draggable">
                    <img src="${DUMMY_QR}" />
                </div>
            `);
            }
            else {
                el = $(`<div class="draggable">${field}</div>`);
            }

            el.attr("data-field", field);

            el.css({
                position: "absolute",
                top: item.MarginTop,
                left: item.MarginLeft,
                width: item.TotalWidth,
                height: item.TotalHeight,
                fontSize: item.FontSize + "px",
                fontWeight: item.FontWeight,
                zIndex: 9999
            });

            $("#badgeArea").append(el);

            makeInteractive(el);
        });
    }


    // ================= INTERACTION =================
    function makeInteractive(el) {

        if (el.data("ui-draggable")) el.draggable("destroy");
        if (el.data("ui-resizable")) el.resizable("destroy");

        el.draggable({
            containment: "#badgeArea",
            cursor: "move",
            cancel: "img", // 🔥 important fix
            start: function () {
                $(this).css("z-index", 9999);
            }
        }).resizable();

        el.off("click").on("click", function (e) {
            e.stopPropagation();
            $(".draggable").removeClass("selected");
            $(this).addClass("selected");
            selected = $(this);
        });
    }


    // ================= DESELECT =================
    $(document).on("click", "#badgeArea", function () {
        $(".draggable").removeClass("selected");
        selected = null;
    });


    // ================= STYLE =================
    function setBold() {
        if (!selected) return;
        if (selected.data("type") === "text") {
            selected.css("font-weight", "bold");
        }
    }

    function setItalic() {
        if (!selected) return;
        if (selected.data("type") === "text") {
            selected.css("font-style", "italic");
        }
    }

    function setFontSize(size) {
        if (!selected) return;

        if (selected.data("type") === "image" || selected.data("type") === "barcode") {
            alert("Font only for text");
            return;
        }

        selected.css("font-size", size + "px");
    }

    // ================= SAVE =================
    function saveLayout() {
        let layout = [];
        $("#badgeArea .draggable").each(function () {

            let el = $(this);
            layout.push({
                field: el.data("field"),
                type: el.data("type"),
                top: parseInt(el.css("top")),
                left: parseInt(el.css("left")),
                width: el.width(),
                height: el.height(),
                fontSize: parseInt(el.css("font-size")) || 14,
                bold: el.css("font-weight") == "bold",
                italic: el.css("font-style") == "italic"
            });
        });
        $("#saveLoaderOverlay").removeClass("d-none");
        $.ajax({
            url: '/Admin/SaveCertificateTemplate',
            type: 'POST',
            data: JSON.stringify({
                EventId: $("#EventId").val(),   // 🔥 IMPORTANT
                LayoutJson: JSON.stringify(layout),
                BackgroundImage: "/uploads/badge.png"
            }),
            contentType: 'application/json',
            success: function (res) {
                if (res.success) {
                    $("#saveLoaderOverlay").addClass("d-none");
                    alert(res.msg);
                    
                } else {
                    alert(res.msg);
                }
            }
        });
    }
</script>
