<script>
    function Editcode(btn) {
        var row = $(btn).closest("tr"); // now this is the clicked row
        $("#txteditname").val(row.find("td:eq(1) .val-name").text().trim());
        $("#hfbadgeid").val(row.find("td:eq(2) .val-sudo").text().trim());
        $("#txteditdesignation").val(row.find("td:eq(3)").text());
        $("#txteditcomapny").val(row.find("td:eq(4)").text());
        $('#modeleditbadge').modal('show');
    }
</script>
<script>
    function UpdateBadge() {
        var BadgeId = $("#hfbadgeid").val();
        var mName = $("#txteditname").val();
        var Company = $("#txteditdesignation").val();
        var Designation = $("#txteditcomapny").val();
        $.ajax({
            url: '@Url.Action("UpdateBadge", "Home")',
            type: 'POST',
            data: { BadgeId: BadgeId, Name: mName, Company: Company, Designation: Designation },
            success: function (response) {
                if (response.success) {
                    alert("details update successfully.After refrest it will display.Please print this page.")
                    $('#modeleditbadge').modal('hide');
                }
                else {
                    alert(response.message);
                    window.location.href = '@Url.Action("MasterSearchBadge", "Home")';
                }
            },
            error: function () {
                alert('An error occurred');
            }
        });
    }
</script>






