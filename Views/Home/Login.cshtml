@using System.Web.Optimization
@{
    Layout = null;

}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Management - Login</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/Content/jquery-ui.css" rel="stylesheet" />
    <link href="~/Content/dataTables.dataTables.min.css" rel="stylesheet" />
    <link href="~/Content/custom.css" rel="stylesheet" />
    <link href="~/Content/Site.css" rel="stylesheet" />
    <link href="~/Content/all.min.css" rel="stylesheet" />
</head>
<body class="login-page">
    <div class="login-card text-center">

        <!-- Logo -->
        <div class="login-logo mb-3">
            <img src="~/Content/images/logo.jpeg" alt="Logo">
        </div>
        <hr />

        @using (Html.BeginForm("LoginCode", "Home", FormMethod.Post,
               new { role = "form", enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true)

            <div class="mb-3 text-start">
                <label class="form-label fw-semibold">
                    <i class="fa fa-envelope"></i> Email ID
                </label>
                <input type="text"
                       class="form-control form-control-lg"
                       name="UserName"
                       placeholder="Enter Email"
                       maxlength="70"
                       required />
            </div>

            <div class="mb-3 text-start">
                <label class="form-label fw-semibold">
                    <i class="fa fa-lock"></i> Password
                </label>
                <div class="password-container">
                    <input class="form-control form-control-lg"
                           id="txtpassword"
                           name="Pass"
                           placeholder="Enter Password"
                           maxlength="15"
                           type="password"
                           required />
                    <span class="password-toggle-icon" id="togglePassword">
                        <i class="fa fa-eye"></i>
                    </span>
                </div>
            </div>

            <button type="submit" class="btn btn-success btn-lg w-100">
                <i class="fa fa-sign-in"></i> Login
            </button>

            <p class="text-danger small mt-2">
                <i class="fa fa-info-circle"></i> Password is case sensitive
            </p>
        }
    </div>
    <div class="modal" tabindex="-1" id="mdlmsg" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background-color:#F1F1F1">
                <div class="modal-header">
                    <h5 class="modal-title"><b>Alert</b></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (@TempData["Msg"] != null)
                    {
                        <p><strong>@TempData["Msg"]</strong></p>
                    }
                </div>
            </div>
        </div>
    </div>
    <script src="~/Scripts/jquery-3.7.1.min.js"></script>
    <script src="~/Scripts/jquery.validate.js"></script>
    <script src="~/Scripts/jquery-ui.min.js"></script>
    <script src="~/Scripts/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/bootstrap.js"></script>
    <script src="~/Scripts/all.min.js"></script>
    <script src="~/Scripts/dataTables.min.js"></script>

    <script>
  $(document).ready(function () {
      if ('@TempData["Msg"]' !== "") {
          $("#mdlmsg").modal('show');
      }
  });
    </script>
    <script>
        const togglePassword = document.getElementById('togglePassword');
        const passwordField = document.getElementById('txtpassword');
        togglePassword.addEventListener('click', function () {
            const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordField.setAttribute('type', type);
            // Toggle the icon class
            this.querySelector('i').classList.toggle('fa-eye');
            this.querySelector('i').classList.toggle('fa-eye-slash');
        });
    </script>
</body>
</html>
