@model EventManagement.Models.AddBadgeCode
@{
    ViewBag.Title = "AddNewBadge";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string mItemPhto = "null";
}

<div class="container bg-light">
    <div class="m-3">
        <section class="row">
            <h3 class="p-1">Add-New Badge</h3>
            <div class="col-12 m-2">
                <form id="mBadgeform">
                    <div class="row">
                        @if (Model?.masterBadgeSave != null)
                        {
                            foreach (var item in Model.masterBadgeSave)
                            {
                                <div class="col-4 p-2">
                                    <div id="divcategory">
                                        <label>Select Category <span class="text-danger">*</span></label>
                                        <select id="Category" name="Category" class="form-select" tabindex="1">
                                            @if (Model?.EventCatAll != null)
                                            {
                                                <option value="">--Select--</option>
                                                foreach (var items in Model.EventCatAll)
                                                {
                                                    <option value="@items.CategoryName">@items.CategoryName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="clearfix mt-1"></div>
                                    <div id="divcompsny">
                                        <label>Company</label>
                                        <input type="text" id="Company" tabindex="3" name="Company" maxlength="75" placeholder="Please fill company" class="form-control alphanumericOnly" />
                                    </div>
                                    <div class="clearfix mt-1"></div>
                                    <div id="divMobile">
                                        <label>Mobile</label>
                                        <input type="text" id="Mobile" tabindex="5" name="Mobile" maxlength="10" placeholder="Please fill mobile" class="form-control Mobile" />
                                    </div>
                                    <div class="clearfix mt-1"></div>
                                    <div id="divphoto">
                                        <label>Photo</label>
                                        <input type="file" id="Photo" name="Photo" tabindex="7" maxlength="70" placeholder="Please select file only png,jpeg,jpg" class="form-control" />
                                        <p class="text-danger">Only png or jpg allowed.</p>
                                        <p style="display:none;"> @mItemPhto = @item.Photo;</p>
                                    </div>
                                    @if (item.Photo == false)
                                    {
                                        mItemPhto = "";
                                    }
                                    <div class="clearfix mt-1"></div>
                                </div>
                                <div class="col-4 p-2">
                                    <div id="divName">
                                        <label>Name <span class="text-danger">*</span></label>
                                        <input type="text" id="Name" name="Name" tabindex="2" maxlength="75" placeholder="Please fill name" class="form-control alphanumericOnly" />
                                    </div>
                                    <div class="clearfix mt-1"></div>
                                    <div id="divDesignation">
                                        <label>Designation</label>
                                        <input type="text" id="Designation" tabindex="4" name="Designation" maxlength="75" placeholder="Please fill designation" class="form-control alphanumericOnly" />
                                    </div>
                                    <div class="clearfix mt-1"></div>
                                    <div id="divEmail">
                                        <label>Email</label>
                                        <input type="email" id="Email" tabindex="6" name="Email" maxlength="35" placeholder="Please fill email" class="form-control" />
                                    </div>
                                    <div class="clearfix mt-1"></div>
                                    <div id="divcountry">
                                        <label>Country <span class="text-danger">*</span></label>
                                        <select id="Country" name="Country" class="form-select" tabindex="7">
                                            @if (Model?.EventCatAll != null)
                                            {
                                                foreach (var items in Model.mastercountry)
                                                {
                                                    <option value="@items.CountryName">@items.CountryName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="clearfix mt-1"></div>
                                </div>
                                <div class="col-4 p-2 border-start">

                                    <p>Please select checkbox to print data (Only selected checkbox will print on Badge)</p>
                                    <span class="fw-bold">
                                        <input type="checkbox" class="print-field form-check-input" value="Name" checked /> Name
                                    </span>

                                    <span class="fw-bold">
                                        <input type="checkbox" class="print-field form-check-input" value="Company" checked /> Company
                                    </span>

                                    <span class="fw-bold">
                                        <input type="checkbox" class="print-field form-check-input" value="BarCode" checked /> BarCode
                                    </span>

                                    <span class="fw-bold">
                                        <input type="checkbox" class="print-field form-check-input" value="Designation" /> Designation
                                    </span>
                                    <div class="clearfix mt-1"></div>
                                    <span class="fw-bold">
                                        <input type="checkbox" class="print-field form-check-input" value="Category" /> Category
                                    </span>

                                    <span class="fw-bold">
                                        <input type="checkbox" class="print-field form-check-input" value="Country" /> Country
                                    </span>

                                    <span class="fw-bold">
                                        <input type="checkbox" class="print-field form-check-input" value="Photo" /> Photo
                                    </span>
                                    <div class="clearfix mt-1"></div>
                                    <p class="text-danger">Only selected field from admin side hide or show while print after checkbox click</p>

                                </div>
                                <div class="clearfix mt-1"></div>
                                <div class="col-8">
                                    <div id="divRemarks">
                                        <label>Remarks (max length 150 charactor)</label>
                                        <input type="text" id="Remarks" tabindex="8" name="Remarks" maxlength="150"
                                               placeholder="Please fill remarks" style="border:1px solid thin; border-radius:5px; height:150px;width:100%" />
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </form>
                <div class="clearfix mt-2"></div>
                <div class="text-center col-8">
                    <input type="submit" id="saveBtn" value="Submit" tabindex="9" class="btn btn-success" />
                    <input type="submit" value="Reset" tabindex="10" class="btn btn-warning" />
                </div>
                <div class="clearfix mt-2"></div>
                <p class="text-danger">Field with * marks are mandatory</p>
                <br />
            </div>
        </section>
    </div>
</div>
<div class="modal fade" id="modelprintbadge" tabindex="-1" role="dialog" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-body">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">X</button>
                <div class="clearfix mt-2"></div>
                <div class="text-center">
                    <input type="button" id="btnprint" class="btn btn-success" value="Print" />
                </div>
                <div class="clearfix mt-2"></div>
                <div id="divshowpanel" style="display: flex; justify-content: center;">
                </div>
                <div class="clearfix mt-3"></div>
            </div>
        </div>
    </div>
</div>
    <script>
        $(document).ready(function () {
            $('.Mobile').on('keypress', function (e) {
                if ($.inArray(e.keyCode, [8, 9, 27, 13]) !== -1 ||
                    (e.keyCode == 65 && (e.ctrlKey === true || e.metaKey === true)) ||
                    (e.keyCode == 67 && (e.ctrlKey === true || e.metaKey === true)) ||
                    (e.keyCode == 86 && (e.ctrlKey === true || e.metaKey === true)) ||
                    (e.keyCode == 88 && (e.ctrlKey === true || e.metaKey === true)) ||
                    (e.keyCode >= 35 && e.keyCode <= 39)) {
                    return;
                }
                if ((e.shiftKey || (e.keyCode < 48 || e.keyCode > 57))) {
                    e.preventDefault();
                }
            });
        });
    </script>
    <script>
        $('.alphanumericOnly').on('input', function () {
            $(this).val(function (_, val) {
                return val.replace(/[^a-zA-Z0-9]/g, '');
            });
        });
    </script>
    <script>
        $('.varcharOnly').on('input', function () {
            $(this).val(function (_, val) {
                return val.replace(/[^a-zA-Z\s]/g, '');
            });
        });
    </script>
    <script>
        $('#saveBtn').click(function (e) {
            e.preventDefault();
            var formData = new FormData();
            formData.append("Name", $("#Name").val());
            formData.append("Category", $("#Category").val());
            formData.append("Designation", $("#Designation").val());
            formData.append("Company", $("#Company").val());
            formData.append("Mobile", $("#Mobile").val());
            formData.append("Email", $("#Email").val());
            formData.append("Country", $("#Country").val());
            formData.append("Remarks", $("#Remarks").val());
            var p = $("#Photo")[0].files[0];
            if (p) formData.append("Photo", p);
            var selected = [];
            $(".print-field:checked").each(function () {
                selected.push($(this).val());
            });
            formData.append("SelectedFields", selected.join(","));

            $.ajax({
                url: '/Home/MasterBadgeSaveCodeandPrint',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                success: function (response) {
                    if (response.success) {
                        $("#divshowpanel").html(response.html);
                        $("#modelprintbadge").modal("show");
                    } else {
                        alert(response.message);
                    }
                }
            });
        });
    </script>
    <script>
        $('#btnprint').click(function () {
            var html = $("#divprint").prop("outerHTML");
            var printWindow = window.open("", "", "height=600,width=800");
            printWindow.document.write(`
                <html>
                <head>
                    <style>
                        body { margin:0; padding:0; }
                        @@media print {
                            #divprint { page-break-after: always; }
                        }
                    </style>
                </head>
                <body>${html}</body>
                </html>
            `);
            printWindow.document.close();
            printWindow.focus();
            printWindow.print();
            printWindow.close();
            $.post('/Home/updatebadgeafterprint',
                { BadgeId: $("#badgeid").val() },
                function (response) {
                    if (!response.success) alert("Error updating print");
                }
            );
        });
    </script>

